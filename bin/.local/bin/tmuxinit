#!/bin/bash

set -e

if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    echo "Usage: $(basename "$0")"
    echo "Initialise tmux windows for a project directory."
    echo "Options:"
    echo "  -h, --help    Show this help message and exit"
    exit 0
fi

if [ -z "$TMUX" ]; then
    BASE="$(basename "$PWD")"
    SESSION="$BASE"
    n=1
    while tmux has-session -t "$SESSION" 2>/dev/null; do
        n=$((n + 1))
        if [ "$n" -gt 10 ]; then
            echo "Error: too many sessions named '${BASE}*'." >&2
            exit 1
        fi
        SESSION="${BASE}${n}"
    done
    W1=$(tmux new-session -d -s "$SESSION" -P -F '#{window_id}')
    tmux send-keys -t "$W1" "hx" Enter
    W2=$(tmux new-window -t "$SESSION" -P -F '#{window_id}')
    tmux split-window -v -t "$W2"
    tmux split-window -h -t "$W2"
    tmux select-pane -t "$W2.{top-left}"
    W3=$(tmux new-window -t "$SESSION" -P -F '#{window_id}')
    tmux send-keys -t "$W3" "claude" Enter
    W4=$(tmux new-window -t "$SESSION" -P -F '#{window_id}')
    tmux send-keys -t "$W4" "lg" Enter
    tmux select-window -t "$W1"
    exec tmux attach-session -t "$SESSION"
fi

tmux send-keys "hx" Enter

tmux new-window
tmux split-window -v
tmux split-window -h
tmux select-pane -t 0

tmux new-window
tmux send-keys "claude" Enter

tmux new-window
tmux send-keys "lg" Enter

tmux select-window -t :^
