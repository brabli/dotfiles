#!/bin/bash

set -e

if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    echo "Usage: $(basename "$0")"
    echo "Initialise tmux windows for a project directory."
    echo "Options:"
    echo "  -h, --help    Show this help message and exit"
    exit 0
fi

if [ -z "$TMUX" ]; then
    read -r -p "You are not inside a tmux session. Start a new one? [y/N] " response
    case "$response" in
        [yY][eE][sS]|[yY])
            tmux new-session -d -s 0
            tmux send-keys -t 0 "$0" Enter
            exec tmux attach-session -t 0
            ;;
        *)
            echo "Aborted." >&2
            exit 1
            ;;
    esac
fi

tmux send-keys "hx" Enter

tmux new-window
tmux split-window -v
tmux split-window -h
tmux select-pane -t 0

tmux new-window
tmux send-keys "claude" Enter

tmux new-window
tmux send-keys "lg" Enter

tmux select-window -t :^
